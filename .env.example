# Gemini API (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Firebase Realtime Database (https://console.firebase.google.com → Projekt → Realtime Database)
FIREBASE_DATABASE_URL=https://<projekt-id>-default-rtdb.<region>.firebasedatabase.app

# Firebase Service Account JSON (einzeilig, aus Firebase Console → Projekteinstellungen → Dienstkonten → Neuen privaten Schlüssel generieren)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
